# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nouveau?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long

# Admin Credentials (auto-created on first start)
ADMIN_EMAIL=admin@nouveau.com
ADMIN_PASSWORD=Admin@Nouveau2024!

# Frontend URLs
CLIENT_URLS=http://localhost:3000,https://nouveau-delta.vercel.app
# Supported aliases: CLIENT_URL, PRODUCTION_URL, FRONTEND_URL

# Optional: Email Service
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Optional: Cloudinary (for image uploads)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
